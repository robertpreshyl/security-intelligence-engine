# ═══════════════════════════════════════════════════
# AllysecLabs AI-SOC Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# WARNING: .env contains secrets — never commit it!
# ═══════════════════════════════════════════════════

# ── Wazuh API ──
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=           # Your Wazuh API password
WAZUH_VERIFY_SSL=False        # False for self-signed certs

# ── Wazuh Dashboard ──
# Used for generating clickable links in reports
WAZUH_DASHBOARD_URL=https://localhost    # Your Wazuh dashboard URL

# ── Alert Source ──
WAZUH_ALERT_FILE=/var/ossec/logs/alerts/alerts.json
WAZUH_MIN_ALERT_LEVEL=3

# ── Groq LLM API (Primary — Cloud) ──
# Free tier: 30 req/min, 14,400 req/day
# Get your key at: https://console.groq.com
GROQ_API_KEY=                 # Your Groq API key (starts with gsk_)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (Self-Hosted) ──
# No rate limits, private, runs on your own infrastructure
# OLLAMA_API_URL=http://localhost:11434/v1/chat/completions
# OLLAMA_API_KEY=ollama

# ── OpenRouter (100+ models via single API) ──
# Pay-per-token across all providers. Get key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# ── OpenAI ──
# GPT-4o, GPT-4o-mini. Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── Anthropic (Claude) ──
# Claude 4 Sonnet/Haiku. Get key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# ── Google Gemini ──
# Get key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=

# ── Logging ──
LOG_LEVEL=INFO
LOG_FILE=logs/ai-soc.log
